{
  "name": "typed-bus",
  "version": "0.1.0",
  "description": "Deterministic typed pub/sub bus for hexagonal architecture",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "index.ts"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "pubsub",
    "event-bus",
    "typescript",
    "hexagonal-architecture",
    "ports-and-adapters"
  ],
  "license": "MIT"
}
